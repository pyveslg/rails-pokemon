<div class="container-fluid my-3">
  <div class="grid-two">
    <div class="left-content">
      <%= link_to "← Pokedex", :back %>
      <p class="my-3">
        Vous entendez un bruit. Un pokemon apparaît dans les hautes herbes...
      </p>
      <div class="pokemon-card">
        <%= cl_image_tag @pokemon.photo.key %>
        <h2><%= @pokemon.name %></h2>
        <p><%= @pokemon.element_type %></p>
      </div>
    </div>
    <div class="right-content">
      <%= simple_form_for [@pokemon, Pokeball.new ] do |f| %>
        <%= f.association :trainer %>
        <%= f.input :location %>
        <%= f.input :caught_on %>
        <%= f.submit "Catch!", class: "btn btn-primary" %>
      <% end %>
      
    </div>
  </div>

</div>