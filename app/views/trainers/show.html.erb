<div class="container-fluid my-3">
  <%= link_to "← Dresseurs", trainers_path %>
  <h1 class="my-3"><%= @trainer.name %> va tous les attraper !</h1>
  <div class="grid-two">
    <div class="left-content">
      <div class="sticky-top mt-3">
        <%= render @trainer %>
      </div>
    </div>
    <div class="right-content mt-3">
      <!-- DISPLAY POKEMONS -->
      <%# @trainer.pokeballs.each do |pokeball| %>
        <!-- <div class="pokemon-card"> -->
          <%#= cl_image_tag pokeball.pokemon.photo.key %>
          <!-- <h2><%#= pokeball.pokemon.name %></h2>
          <p><%#= pokeball.pokemon.element_type %></p>
          <p>Caught on <%#= pokeball.caught_on %> at <%#= pokeball.location %></p>
        </div> -->
      <%# end %> 

      <h2><%= @trainer.name %> a attrapé <%= @pokemons.count %> pokemons.</h2>
      <div class="grid-two">
        <% @pokemons.each do |pokemon| %>
          <div class="pokemon-card">
            <%= link_to pokemon_path(pokemon) do %>
              <%= cl_image_tag pokemon.photo.key %>
              <h2><%= pokemon.name %></h2>
            <% end %>
            <p><%= pokemon.element_type %></p>
            <p>Attrapé le <%= pokemon.pokeball.caught_on.strftime("%-d %b %Y") %> à <%= pokemon.pokeball.location %></p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>